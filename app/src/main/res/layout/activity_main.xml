<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background">

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📚 To-Do + Fokus Belajar"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kelola tugas dan tingkatkan fokus belajarmu"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tvTotalTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total tugas: 0"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnTambahTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="➕ Tambah Tugas"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/primary"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnMulaiFokus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏳ Mulai Fokus Belajar"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/primary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daftar Tugas"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="10dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTask"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>